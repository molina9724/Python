{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Tests (pytest)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-k",
                "${selectedText}",
                "-p",
                "no:xdist",
                "-o",
                "addopts=",
                "--headed",
                "--browser",
                "chromium"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        }
    ]
}
